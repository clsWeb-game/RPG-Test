  },
  "homepage": "https://github.com/alexkorol/RogueForge#readme",
  "dependencies": {
    "@metamask/detect-provider": "^2.0.0",
    "ethers": "^6.0.0",
    "express": "^4.18.2",
    "logkitx": "^1.0.1",
    "pdfkit": "^0.18.0",
    "phaser": "^3.60.0",
    "pino": "^10.3.0",
    "socket.io": "^4.6.1",
    "three": "^0.151.3"
  },
  "devDependencies": {
